function Write-Log {
    <#
    .SYNOPSIS
        Registra mensagens no console com cor e nível de severidade.
    #>
    param(
        [Parameter(Mandatory)][string]$Mensagem,
        [ValidateSet("INFO","WARN","ERROR","SUCCESS","DEBUG","STEP")]
        [string]$Nivel = "INFO"
    )

    $cores = @{
        INFO    = "Cyan"
        WARN    = "Yellow"
        ERROR   = "Red"
        SUCCESS = "Green"
        DEBUG   = "Gray"
        STEP    = "Magenta"
    }

    $prefixos = @{
        INFO    = "[INFO ]"
        WARN    = "[AVISO]"
        ERROR   = "[ERRO ]"
        SUCCESS = "[  OK ]"
        DEBUG   = "[DEBUG]"
        STEP    = "[ETAPA]"
    }

    if ($Nivel -eq "DEBUG" -and $Script:Config.LogLevel -ne "DEBUG") { return }

    $linha = "{0}  {1}  {2}" -f (Get-Date -Format "HH:mm:ss"), $prefixos[$Nivel], $Mensagem
    Write-Host $linha -ForegroundColor $cores[$Nivel]
    $Script:LogBuffer.Add($linha)
}

