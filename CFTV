# ─────────────────────────────────────────────────────────────────────────────

function Get-RedeLocal {
    <#
    .SYNOPSIS
        Detecta automaticamente IP local, máscara, CIDR, gateway e notação de rede.
    .OUTPUTS
        [PSCustomObject] com propriedades: IP, Mascara, CIDR, Gateway, RedeNotacao, Interface
    #>
    Write-Log "Identificando configurações de rede locais..." -Nivel STEP

    try {
        # Seleciona a rota padrão (menor métrica) para determinar a interface principal
        $rotaPadrao = Get-NetRoute -DestinationPrefix "0.0.0.0/0" |
            Where-Object { $_.NextHop -ne "::" -and $_.NextHop -ne "0.0.0.0" } |
            Sort-Object RouteMetric |
            Select-Object -First 1

        if (-not $rotaPadrao) {
            throw "Nenhuma rota padrão (gateway) detectada. Verifique a conectividade de rede."
        }

        $gateway = $rotaPadrao.NextHop
        $ifIndex  = $rotaPadrao.InterfaceIndex

        # Obtém endereço IPv4 da interface selecionada
        $ipCfg = Get-NetIPAddress -InterfaceIndex $ifIndex -AddressFamily IPv4 |
            Where-Object { $_.IPAddress -notmatch "^169\.254" } | # exclui APIPA
            Select-Object -First 1

        if (-not $ipCfg) {
            throw "Não foi possível obter endereço IPv4 válido para a interface $ifIndex."
        }

        $ip       = $ipCfg.IPAddress
        $cidr     = $ipCfg.PrefixLength
        $mascara  = Convert-CIDRParaMascara -CIDR $cidr
        $redeBase = Get-NetworkAddress -IP $ip -CIDR $cidr

        $info = [PSCustomObject]@{
            IP           = $ip
            Mascara      = $mascara
            CIDR         = $cidr
            Gateway      = $gateway
            RedeNotacao  = "$redeBase/$cidr"
            Interface    = (Get-NetAdapter -InterfaceIndex $ifIndex -ErrorAction SilentlyContinue).Name
        }

        Write-Log "IP Local    : $ip" -Nivel INFO
        Write-Log "Máscara     : $mascara (/$cidr)" -Nivel INFO
        Write-Log "Gateway     : $gateway" -Nivel INFO
        Write-Log "Rede Alvo   : $($info.RedeNotacao)" -Nivel INFO
        Write-Log "Interface   : $($info.Interface)" -Nivel INFO

        return $info
    }
    catch {
        Write-Log "Erro ao descobrir rede local: $_" -Nivel ERROR
        throw
    }
}

function Convert-CIDRParaMascara {
    <#
    .SYNOPSIS
        Converte prefixo CIDR (ex: 24) para notação decimal pontilhada (ex: 255.255.255.0).
    #>
    param([Parameter(Mandatory)][ValidateRange(0,32)][int]$CIDR)

    $binario = ("1" * $CIDR).PadRight(32, "0")
    return (0..3 | ForEach-Object {
        [Convert]::ToInt32($binario.Substring($_ * 8, 8), 2)
    }) -join "."
}

function Get-NetworkAddress {
    <#
    .SYNOPSIS
        Calcula o endereço de rede a partir do IP e CIDR.
    #>
    param(
        [Parameter(Mandatory)][string]$IP,
        [Parameter(Mandatory)][int]$CIDR
    )

    $ipBytes      = ([System.Net.IPAddress]::Parse($IP)).GetAddressBytes()
    $maskBytes    = ([System.Net.IPAddress]::Parse((Convert-CIDRParaMascara -CIDR $CIDR))).GetAddressBytes()
    $networkBytes = for ($i = 0; $i -lt 4; $i++) { $ipBytes[$i] -band $maskBytes[$i] }
    return $networkBytes -join "."
}

# ─────────────────────────────────────────────────────────────────────────────
# REGIÃO: DETECÇÃO DE REDES ADICIONAIS
# ─────────────────────────────────────────────────────────────────────────────

function Get-RedesAdicionais {
    <#
    .SYNOPSIS
        Lista interfaces e rotas além da rede principal para detectar segmentação.
    #>
    param([Parameter(Mandatory)][string]$RedeAtual)

    Write-Log "Verificando interfaces e rotas adicionais..." -Nivel STEP

    try {
        # Todos os IPs IPv4 ativos (exclui loopback e APIPA)
        $todosIPs = Get-NetIPAddress -AddressFamily IPv4 |
            Where-Object {
                $_.IPAddress -notmatch "^127\." -and
                $_.IPAddress -notmatch "^169\.254" -and
                $_.PrefixOrigin -ne "WellKnown"
            }

        Write-Log "Interfaces IPv4 ativas detectadas:" -Nivel INFO
        foreach ($addr in $todosIPs) {
            $adapter = (Get-NetAdapter -InterfaceIndex $addr.InterfaceIndex -ErrorAction SilentlyContinue).Name
            Write-Log "  · $($addr.IPAddress)/$($addr.PrefixLength)  [$adapter]" -Nivel INFO
        }

        # Rotas estáticas/específicas (exclui loopback, multicast e broadcast)
        $rotas = Get-NetRoute -AddressFamily IPv4 |
            Where-Object {
                $_.DestinationPrefix -notmatch "^(127\.|224\.|255\.|0\.0\.0\.0/0)" -and
                $_.NextHop -ne "0.0.0.0"
            } |
            Sort-Object DestinationPrefix -Unique

        if ($rotas.Count -gt 0) {
            Write-Log "Rotas adicionais na tabela de roteamento:" -Nivel WARN
            foreach ($rota in $rotas) {
                Write-Log "  · Destino: $($rota.DestinationPrefix)  Via: $($rota.NextHop)" -Nivel WARN
            }
            Write-Log "ATENÇÃO: Múltiplas redes/segmentos detectados. Considere auditar cada sub-rede separadamente." -Nivel WARN
        }
        else {
            Write-Log "Nenhuma rota adicional significativa detectada." -Nivel INFO
        }
    }
    catch {
        Write-Log "Erro ao verificar redes adicionais: $_" -Nivel WARN
        # Não interrompe execução — é informativo
    }
}

