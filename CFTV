function Test-NmapDisponivel {
    <#
    .SYNOPSIS
        Verifica se o Nmap está acessível no PATH. Retorna $true/$false.
    #>
    try {
        $null = Get-Command nmap -ErrorAction Stop
        $versao = (nmap --version 2>&1 | Select-Object -First 1)
        Write-Log "Nmap encontrado: $versao" -Nivel SUCCESS
        return $true
    }
    catch {
        return $false
    }
}

function Install-Nmap {
    <#
    .SYNOPSIS
        Instala o Nmap via Winget de forma silenciosa e valida a instalação.
    #>
    Write-Log "Nmap não localizado. Tentando instalação via Winget..." -Nivel WARN

    # Verifica se Winget está disponível
    try {
        $null = Get-Command winget -ErrorAction Stop
    }
    catch {
        Write-Log "Winget não está disponível neste sistema. Instale o Nmap manualmente: https://nmap.org/download.html" -Nivel ERROR
        throw "Dependência ausente: Winget/Nmap."
    }

    try {
        Write-Log "Executando: winget install Nmap.Nmap (aguarde)..." -Nivel STEP
        $proc = Start-Process -FilePath "winget" `
            -ArgumentList "install -e --id Nmap.Nmap --silent --accept-package-agreements --accept-source-agreements" `
            -Wait -PassThru -NoNewWindow

        if ($proc.ExitCode -notin @(0, -1978335189)) {
            # -1978335189 = já instalado (APPINSTALLER_ERROR_ALREADY_INSTALLED)
            throw "Winget retornou código de saída: $($proc.ExitCode)"
        }

        # Atualiza o PATH da sessão atual para incluir diretório do Nmap
        $nmapDir = "C:\Program Files (x86)\Nmap"
        if (Test-Path $nmapDir) {
            $env:PATH += ";$nmapDir"
            Write-Log "PATH atualizado com: $nmapDir" -Nivel DEBUG
        }

        # Valida instalação
        if (-not (Test-NmapDisponivel)) {
            throw "Nmap instalado, porém não detectado no PATH. Reinicie o terminal e execute novamente."
        }

        Write-Log "Nmap instalado e validado com sucesso." -Nivel SUCCESS
    }
    catch {
        Write-Log "Falha na instalação do Nmap: $_" -Nivel ERROR
        throw
    }
}

function Assert-Dependencias {
    <#
    .SYNOPSIS
        Ponto de entrada para verificação e instalação de todas as dependências.
    #>
    Write-Log "Verificando dependências do script..." -Nivel STEP

    if (-not (Test-NmapDisponivel)) {
        Install-Nmap
    }
}

