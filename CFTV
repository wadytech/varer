# REGIÃO: VARREDURA COM NMAP
# ─────────────────────────────────────────────────────────────────────────────

function Invoke-VarreduraNmap {
    <#
    .SYNOPSIS
        Executa varredura Nmap com parâmetros controlados e retorna saída bruta.
    .PARAMETER RedeAlvo
        Notação CIDR da rede a varrer (ex: 192.168.1.0/24).
    #>
    param([Parameter(Mandatory)][string]$RedeAlvo)

    Write-Log "Iniciando varredura Nmap em: $RedeAlvo" -Nivel STEP
    Write-Log "Portas alvo: $($Script:Config.Portas)" -Nivel INFO

    # Parâmetros Nmap explicados:
    # -sS  : TCP SYN scan (stealth, não completa handshake — requer privilégio admin)
    # -sV  : Detecção de versão de serviço
    # -p   : Portas específicas (sem varrer tudo)
    # --open: Exibe apenas portas abertas
    # --script banner : Captura banners para identificação heurística
    # --host-timeout   : Abandona host sem resposta após N segundos
    # --min-rate/--max-rate : Controla taxa de pacotes (evita sobrecarga em redes corp.)
    # -T4  : Timing agressivo mas controlado (T5 causa falsos negativos em LANs lentas)
    # -oX -: Saída XML no stdout para parsing estruturado
    # -n   : Sem resolução DNS reversa (mais rápido)

    $argumentos = @(
        "-sS", "-sV",
        "-p", $Script:Config.Portas,
        "--open",
        "--script", "banner",
        "--host-timeout", $Script:Config.NmapHostTimeout,
        "--min-rate", $Script:Config.NmapMinRate,
        "--max-rate", $Script:Config.NmapMaxRate,
        "-T4", "-n",
        "-oX", "-",   # XML para stdout → parsing mais confiável que texto
        $RedeAlvo
    )

    Write-Log "Comando: nmap $($argumentos -join ' ')" -Nivel DEBUG

    try {
        $job = Start-Job -ScriptBlock {
            param($args)
            & nmap @args 2>&1
        } -ArgumentList (,$argumentos)

        # Aguarda com timeout de segurança
        $concluiu = Wait-Job -Job $job -Timeout $Script:Config.NmapTimeout

        if (-not $concluiu) {
            Stop-Job  -Job $job
            Remove-Job -Job $job -Force
            throw "Timeout atingido ($($Script:Config.NmapTimeout)s). A rede pode ser muito grande ou lenta."
        }

        $saida = Receive-Job -Job $job
        Remove-Job -Job $job -Force

        if (-not $saida) {
            throw "Nmap não retornou nenhuma saída. Verifique permissões e conectividade."
        }

        Write-Log "Varredura concluída. Processando resultados..." -Nivel SUCCESS
        return $saida -join "`n"
    }
    catch {
        Write-Log "Erro durante varredura Nmap: $_" -Nivel ERROR
        throw
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# REGIÃO: PARSING E CLASSIFICAÇÃO
# ─────────────────────────────────────────────────────────────────────────────

function ConvertFrom-NmapXML {
    <#
    .SYNOPSIS
        Converte saída XML do Nmap em objetos PowerShell estruturados.
    #>
    param([Parameter(Mandatory)][string]$XmlBruto)

    $resultados = [System.Collections.Generic.List[PSCustomObject]]::new()

    try {
        # Isola apenas o bloco XML (Nmap pode emitir avisos antes do XML)
        $xmlInicio = $XmlBruto.IndexOf("<?xml")
        if ($xmlInicio -lt 0) {
            throw "Saída XML não encontrada. Nmap pode não ter retornado resultados válidos."
        }
        $xmlPuro = $XmlBruto.Substring($xmlInicio)

        [xml]$xml = $xmlPuro

        foreach ($host in $xml.nmaprun.host) {
            # Ignora hosts sem endereço ou sem portas abertas
            $addrNode = $host.address | Where-Object { $_.addrtype -eq "ipv4" }
            if (-not $addrNode) { continue }

            $ip = $addrNode.addr

            # Hostname (DNS reverso, se disponível)
            $hostname = ($host.hostnames.hostname | Where-Object { $_.type -eq "PTR" } | Select-Object -First 1)?.name
            if (-not $hostname) { $hostname = "" }

            # Coleta portas abertas
            $portasAbertas = $host.ports.port |
                Where-Object { $_.state.state -eq "open" }

            if (-not $portasAbertas) { continue }

            # Lista de portas e serviços
            $portasList   = [System.Collections.Generic.List[string]]::new()
            $servicosList = [System.Collections.Generic.List[string]]::new()
            $bannersList  = [System.Collections.Generic.List[string]]::new()

            foreach ($porta in $portasAbertas) {
                $numPorta  = $porta.portid
                $protocolo = $porta.protocol
                $svcName   = $porta.service?.name ?? "desconhecido"
                $svcProd   = $porta.service?.product ?? ""
                $svcVer    = $porta.service?.version ?? ""
                $svcInfo   = ($svcName, $svcProd, $svcVer | Where-Object { $_ }) -join " "

                # Banner via script NSE
                $banner = ($porta.script | Where-Object { $_.id -eq "banner" })?.output ?? ""

                $portasList.Add("$numPorta/$protocolo")
                $servicosList.Add($svcInfo.Trim())
                if ($banner) { $bannersList.Add("[$numPorta] $banner") }
            }

            $resultados.Add([PSCustomObject]@{
                IP            = $ip
                Hostname      = $hostname
                Portas        = $portasList -join " | "
                Servicos      = $servicosList -join " | "
                Banners       = $bannersList -join " | "
                PortasLista   = $portasList   # mantido para classificação (não vai pro CSV direto)
                ServicosLista = $servicosList
            })
        }

        Write-Log "$($resultados.Count) host(s) com portas abertas encontrado(s)." -Nivel INFO
        return $resultados
    }
    catch {
        Write-Log "Erro ao processar XML do Nmap: $_" -Nivel ERROR
        throw
    }
}

function Get-ClassificacaoDispositivo {
    <#
    .SYNOPSIS
        Classifica um dispositivo como DVR/NVR, Câmera IP ou Outro com base em
        portas abertas, serviços e banners detectados.
    #>
    param(
        [Parameter(Mandatory)][string[]]$Portas,
        [Parameter(Mandatory)][string[]]$Servicos,
        [string]$Banners = ""
    )

    # Normaliza para comparação case-insensitive
    $portasNums  = $Portas  | ForEach-Object { ($_ -split "/")[0] }
    $svcsLower   = ($Servicos -join " ").ToLower()
    $bannerLower = $Banners.ToLower()
    $contextLower= "$svcsLower $bannerLower"

    # ── Palavras-chave de banner/serviço que indicam fabricantes CFTV ──────────
    $keywordsDVRNVR = @(
        "dahua","dvr","nvr","hvr","xvr",
        "hikvision","hik-connect",
        "uniview","uniview nvr",
        "hanwha","samsung wisenet",
        "bosch divar",
        "milestone","genetec",
        "cp plus","cpplus"
    )
    $keywordsCamera = @(
        "axis","rtsp","ipcam","ipcamera",
        "vivotek","pelco","flir","mobotix",
        "reolink","amcrest","foscam",
        "onvif","network camera","ip camera","webcam"
    )
    $keywordsRoteador = @(
        "cisco","mikrotik","ubiquiti","unifi",
        "tp-link","d-link","asus router",
        "ssh-","openssh","cisco ios","routeros"
    )

    $temRTSP       = "554"  -in $portasNums
    $temHTTP       = "80"   -in $portasNums -or "8080" -in $portasNums -or "81" -in $portasNums
    $temHTTPS      = "443"  -in $portasNums -or "8443" -in $portasNums
    $temDahua      = "37777" -in $portasNums -or "37778" -in $portasNums
    $temHikvision  = "8000" -in $portasNums
    $temSDKGenerico= "34567" -in $portasNums -or "5000" -in $portasNums
    $temTelnet     = "23"   -in $portasNums
    $temSSH        = "22"   -in $portasNums
    $temFTP        = "21"   -in $portasNums
    $qtdPortas     = $portasNums.Count

    # ── Regras de classificação (ordem de prioridade) ─────────────────────────

    # 1. DVR/NVR: portas proprietárias Dahua ou Hikvision SDK
    if ($temDahua -and ($temRTSP -or $temHTTP)) {
        return "DVR/NVR - Dahua (porta 37777)"
    }
    if ($temHikvision -and ($temRTSP -or $temHTTP)) {
        return "DVR/NVR - Hikvision (porta 8000)"
    }
    if ($temSDKGenerico -and $temRTSP -and $qtdPortas -ge 3) {
        return "DVR/NVR - SDK Genérico (34567/5000)"
    }

    # 2. DVR/NVR por keywords de banner/serviço
    foreach ($kw in $keywordsDVRNVR) {
        if ($contextLower -match [regex]::Escape($kw)) {
            return "DVR/NVR - Identificado por banner ($kw)"
        }
    }

    # 3. Câmera IP: RTSP + HTTP/HTTPS (padrão típico de câmeras modernas)
    if ($temRTSP -and ($temHTTP -or $temHTTPS)) {
        return "Câmera IP (RTSP + HTTP)"
    }

    # 4. Câmera IP apenas por RTSP
    if ($temRTSP) {
        return "Câmera IP (RTSP)"
    }

    # 5. Câmera IP por keywords
    foreach ($kw in $keywordsCamera) {
        if ($contextLower -match [regex]::Escape($kw)) {
            return "Câmera IP - Identificada por banner ($kw)"
        }
    }

    # 6. Roteador/Switch por keywords
    foreach ($kw in $keywordsRoteador) {
        if ($contextLower -match [regex]::Escape($kw)) {
            return "Equipamento de Rede (Roteador/Switch)"
        }
    }

    # 7. Dispositivo com SSH/Telnet/FTP (administração remota)
    if ($temSSH -or $temTelnet -or $temFTP) {
        $adminPorts = @()
        if ($temSSH)    { $adminPorts += "SSH" }
        if ($temTelnet) { $adminPorts += "Telnet" }
        if ($temFTP)    { $adminPorts += "FTP" }

        if ($temTelnet) {
            return "ATENÇÃO: Telnet aberto ($($adminPorts -join '+')) - Risco de Segurança"
        }
        return "Dispositivo c/ Acesso Remoto ($($adminPorts -join '+'))"
    }

    # 8. Somente HTTP/HTTPS → interface web genérica
    if ($temHTTP -or $temHTTPS) {
        return "Interface Web (HTTP/HTTPS)"
    }

    return "Outro Dispositivo de Rede"
}

function Build-Relatorio {
    <#
    .SYNOPSIS
        Processa hosts do Nmap, classifica e monta o relatório final.
    #>
    param(
        [Parameter(Mandatory)][object[]]$Hosts,
        [Parameter(Mandatory)][string]$Gateway,
        [Parameter(Mandatory)][string]$RedeAlvo
    )

    Write-Log "Classificando dispositivos detectados..." -Nivel STEP

    foreach ($h in $Hosts) {
        $classificacao = Get-ClassificacaoDispositivo `
            -Portas   $h.PortasLista `
            -Servicos $h.ServicosLista `
            -Banners  $h.Banners

        # Alerta visual para dispositivos CFTV e riscos de segurança
        $nivel = "INFO"
        if ($classificacao -match "DVR|NVR|Câmera") { $nivel = "SUCCESS" }
        if ($classificacao -match "ATENÇÃO|Telnet")  { $nivel = "WARN"    }

        Write-Log "  $($h.IP.PadRight(16)) → $classificacao" -Nivel $nivel

        $Script:Relatorio.Add([PSCustomObject]@{
            IP                 = $h.IP
            Hostname           = $h.Hostname
            Portas_Abertas     = $h.Portas
            Servicos_Detectados= $h.Servicos
            Banner             = $h.Banners
            Classificacao      = $classificacao
            Rede_Auditada      = $RedeAlvo
            Gateway            = $Gateway
            Data_Varredura     = (Get-Date -Format "dd/MM/yyyy HH:mm:ss")
        })
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# REGIÃO: EXPORTAÇÃO DE RELATÓRIOS
# ─────────────────────────────────────────────────────────────────────────────

function Export-Relatorio {
    <#
    .SYNOPSIS
        Exporta o relatório para CSV (Desktop) e log de texto.
    #>
    $baseName = "Auditoria_CFTV_$($Script:Config.Timestamp)"
    $csvPath  = Join-Path $Script:Config.DesktopPath "$baseName.csv"
    $logPath  = Join-Path $Script:Config.DesktopPath "$baseName.log"

    Write-Log "Exportando relatório para: $csvPath" -Nivel STEP

    try {
        if ($Script:Relatorio.Count -eq 0) {
            Write-Log "Nenhum dispositivo com portas abertas foi encontrado. Relatório vazio." -Nivel WARN

            # Gera CSV vazio com cabeçalho para consistência
            [PSCustomObject]@{
                IP = ""; Hostname = ""; Portas_Abertas = ""; Servicos_Detectados = ""
                Banner = ""; Classificacao = "SEM_RESULTADOS"
                Rede_Auditada = ""; Gateway = ""; Data_Varredura = ""
            } | Export-Csv -Path $csvPath -NoTypeInformation -Encoding UTF8
        }
        else {
            $Script:Relatorio | Export-Csv -Path $csvPath -NoTypeInformation -Encoding UTF8
        }

        # Log de auditoria completo (console + arquivo)
        $Script:LogBuffer | Out-File -FilePath $logPath -Encoding UTF8

        Write-Log "CSV salvo  : $csvPath" -Nivel SUCCESS
        Write-Log "Log salvo  : $logPath" -Nivel SUCCESS

        # Resumo executivo no console
        Write-Host ""
        Write-Host "══════════════════════════════════════════════════════" -ForegroundColor Cyan
        Write-Host "  RESUMO DA AUDITORIA CFTV" -ForegroundColor Cyan
        Write-Host "══════════════════════════════════════════════════════" -ForegroundColor Cyan

        $grupos = $Script:Relatorio | Group-Object { ($_.Classificacao -split " - ")[0] } | Sort-Object Count -Descending
        foreach ($g in $grupos) {
            Write-Host ("  {0,-40} {1,3} dispositivo(s)" -f $g.Name, $g.Count) -ForegroundColor White
        }

        Write-Host ("  {0,-40} {1,3} total" -f "TOTAL DE DISPOSITIVOS:", $Script:Relatorio.Count) -ForegroundColor Yellow
        Write-Host "══════════════════════════════════════════════════════" -ForegroundColor Cyan
        Write-Host ""
    }
    catch {
        Write-Log "Erro ao exportar relatório: $_" -Nivel ERROR
        throw
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# REGIÃO: PONTO DE ENTRADA PRINCIPAL
# ─────────────────────────────────────────────────────────────────────────────

function Invoke-AuditoriaCFTV {
    <#
    .SYNOPSIS
        Orquestra todas as etapas da auditoria de rede CFTV.
    #>

    Write-Host ""
    Write-Host "══════════════════════════════════════════════════════" -ForegroundColor Cyan
    Write-Host "  AUDITORIA DE REDE CFTV PROFISSIONAL v2.0" -ForegroundColor Cyan
    Write-Host "  $(Get-Date -Format 'dd/MM/yyyy HH:mm:ss')" -ForegroundColor Gray
    Write-Host "══════════════════════════════════════════════════════" -ForegroundColor Cyan
    Write-Host ""

    # ETAPA 1 — Dependências
    try {
        Assert-Dependencias
    }
    catch {
        Write-Log "Abortando: dependência crítica não satisfeita. $_" -Nivel ERROR
        exit 1
    }

    # ETAPA 2 — Descoberta de rede
    try {
        $rede = Get-RedeLocal
    }
    catch {
        Write-Log "Abortando: não foi possível identificar a rede local. $_" -Nivel ERROR
        exit 1
    }

    # ETAPA 3 — Redes adicionais (informativo)
    Get-RedesAdicionais -RedeAtual $rede.RedeNotacao

    # ETAPA 4 — Varredura Nmap
    try {
        $xmlSaida = Invoke-VarreduraNmap -RedeAlvo $rede.RedeNotacao
    }
    catch {
        Write-Log "Abortando: falha na varredura de rede. $_" -Nivel ERROR
        exit 1
    }

    # ETAPA 5 — Parsing do XML
    try {
        $hosts = ConvertFrom-NmapXML -XmlBruto $xmlSaida
    }
    catch {
        Write-Log "Abortando: não foi possível processar os resultados do Nmap. $_" -Nivel ERROR
        exit 1
    }

    # ETAPA 6 — Classificação e relatório
    if ($hosts.Count -gt 0) {
        Build-Relatorio -Hosts $hosts -Gateway $rede.Gateway -RedeAlvo $rede.RedeNotacao
    }
    else {
        Write-Log "Nenhum host respondeu na varredura. Verifique firewall e conectividade." -Nivel WARN
    }

    # ETAPA 7 — Exportação
    try {
        Export-Relatorio
    }
    catch {
        Write-Log "Aviso: erro ao exportar. Verifique permissões no Desktop. $_" -Nivel WARN
    }

    Write-Log "Auditoria finalizada." -Nivel SUCCESS
}

# ─────────────────────────────────────────────────────────────────────────────
# EXECUÇÃO
# ─────────────────────────────────────────────────────────────────────────────
Invoke-AuditoriaCFTV
